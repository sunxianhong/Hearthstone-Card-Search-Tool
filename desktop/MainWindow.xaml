<Window x:Class="HearthstoneCardSearchTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="炉石卡牌搜索工具"
        Width="1320"
        Height="880"
        MinWidth="1080"
        MinHeight="760"
        Background="#F1E5CF"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#F8F2E8" />
            <Setter Property="Foreground" Value="#2A2118" />
            <Setter Property="BorderBrush" Value="#B89B67" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F2E6D3" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E9D9BE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardTileButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="Background" Value="#FFFDF8" />
            <Setter Property="Foreground" Value="#2A2118" />
            <Setter Property="BorderBrush" Value="#BEA06D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SelectableDisplayTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="IsReadOnlyCaretVisible" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="IsTabStop" Value="True" />
            <Setter Property="Cursor" Value="IBeam" />
            <Setter Property="SelectionBrush" Value="#D3B382" />
            <Setter Property="SelectionTextBrush" Value="#2A2118" />
            <Setter Property="CaretBrush" Value="#2A2118" />
        </Style>

        <Style x:Key="TagLineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource SelectableDisplayTextBoxStyle}">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Background" Value="#FBF4E8" />
            <Setter Property="BorderBrush" Value="#A49374" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#3B2F22" />
        </Style>

        <Style x:Key="CenteredComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="Background" Value="#FFFDF8" />
            <Setter Property="Foreground" Value="#2A2118" />
            <Setter Property="BorderBrush" Value="#BEA06D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource CenteredComboBoxItemStyle}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F7EEDF" Offset="0" />
                <GradientStop Color="#E6D4B4" Offset="0.55" />
                <GradientStop Color="#D5B98A" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer x:Name="MainScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="True">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="0,0,0,10"
                        CornerRadius="22"
                        BorderBrush="#C3A879"
                        BorderThickness="1"
                        Background="#FBF6EE">
                    <Grid Margin="16,12">
                            <TextBox Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                     FontSize="28"
                                     FontWeight="Bold"
                                     Foreground="#2A2118"
                                     Text="炉石卡牌搜索台" />

                            <Border HorizontalAlignment="Right"
                                    Visibility="Collapsed">
                                <TextBox x:Name="SearchModeText"
                                         Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                         FontSize="14"
                                         Foreground="#6B573C"
                                         Text="普通搜索" />
                            </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,0,0,10"
                        CornerRadius="22"
                        BorderBrush="#C3A879"
                        BorderThickness="1"
                        Background="#FBF6EE">
                    <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        x:Name="SearchControlsPanel"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left">
                                <StackPanel x:Name="SearchInputPanel"
                                            Margin="0,0,8,0">
                                    <TextBox Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                             FontSize="13"
                                             FontWeight="Bold"
                                             Foreground="#6E542D"
                                             Text="搜索输入" />
                                    <TextBox x:Name="SearchTextBox"
                                             Margin="0,6,0,0"
                                             Height="42"
                                             Padding="12,6"
                                             FontSize="16"
                                             Background="#FFFDF8"
                                             BorderBrush="#BEA06D"
                                             BorderThickness="1"
                                             VerticalContentAlignment="Center"
                                             Text="" />
                                </StackPanel>

                                <Button x:Name="ApplyFiltersButton"
                                        Width="{Binding ElementName=CostComboBox, Path=ActualWidth}"
                                        Height="42"
                                        Margin="0,19,8,0"
                                        FontSize="15"
                                        FontWeight="Bold"
                                        Content="筛选 / 搜索" />

                                <Button x:Name="ResetFiltersButton"
                                        Width="92"
                                        Height="42"
                                        Margin="0,19,0,0"
                                        FontSize="15"
                                        FontWeight="Bold"
                                        Content="重置" />
                            </StackPanel>

                            <Grid x:Name="FilterGrid"
                                  Grid.Row="1"
                                  Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="ModeComboBox"
                                          Grid.Column="0"
                                          Margin="0,0,8,0"
                                          Height="40"
                                          FontSize="13"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value" />

                                <ComboBox x:Name="SetComboBox"
                                          Grid.Column="1"
                                          Margin="0,0,8,0"
                                          Height="40"
                                          FontSize="13"
                                          MaxDropDownHeight="500"
                                          ScrollViewer.CanContentScroll="False"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value">
                                    <ComboBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid IsItemsHost="True"
                                                         Columns="3" />
                                        </ItemsPanelTemplate>
                                    </ComboBox.ItemsPanel>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource CenteredComboBoxItemStyle}">
                                            <Setter Property="MinWidth" Value="132" />
                                            <Setter Property="Height" Value="36" />
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>

                                <ComboBox x:Name="CostComboBox"
                                          Grid.Column="2"
                                          Margin="0,0,8,0"
                                          Height="40"
                                          FontSize="13"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value" />
                                <ComboBox x:Name="ClassComboBox"
                                          Grid.Column="3"
                                          Margin="0,0,8,0"
                                          Height="40"
                                          FontSize="13"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value" />
                                <ComboBox x:Name="RarityComboBox"
                                          Grid.Column="4"
                                          Margin="0,0,8,0"
                                          Height="40"
                                          FontSize="13"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value" />
                                <ComboBox x:Name="TypeComboBox"
                                          Grid.Column="5"
                                          Margin="0,0,8,0"
                                          Height="40"
                                          FontSize="13"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value" />
                                <ComboBox x:Name="RaceComboBox"
                                          Grid.Column="6"
                                          Margin="0,0,8,0"
                                          Height="40"
                                          FontSize="13"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value" />
                                <ComboBox x:Name="SchoolComboBox"
                                          Grid.Column="7"
                                          Margin="0,0,8,0"
                                          Height="40"
                                          FontSize="13"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value" />
                                <ComboBox x:Name="KeywordComboBox"
                                          Grid.Column="8"
                                          Margin="0,0,8,0"
                                          Height="40"
                                          FontSize="13"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value" />
                                <ComboBox x:Name="CollectibleComboBox"
                                          Grid.Column="9"
                                          Height="40"
                                          FontSize="13"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value" />
                            </Grid>

                            <TextBox x:Name="StatusTextBlock"
                                     Grid.Row="2"
                                     Margin="0,10,0,0"
                                     Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                     FontSize="14"
                                     Foreground="#69553D" />
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Padding="14"
                        CornerRadius="22"
                        BorderBrush="#C3A879"
                        BorderThickness="1"
                        Background="#FBF6EE">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Margin="0,0,0,0"
                                    Visibility="Collapsed">
                            <TextBox Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                     FontSize="20"
                                     FontWeight="Bold"
                                     Foreground="#2A2118"
                                     Text="卡牌墙" />
                            <TextBox x:Name="ResultHintText"
                                     Margin="0,4,0,0"
                                     Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                     FontSize="13"
                                     Foreground="#66513A"
                                     Text="图片一张挨着一张显示，点击打开详情。" />
                        </StackPanel>

                        <Grid x:Name="CardWallPanel"
                              Grid.Row="1"
                              Margin="0,8,0,0" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <Grid x:Name="DetailOverlay"
              Background="#9A140D08"
              Visibility="Collapsed">
            <Viewbox x:Name="DetailModalHost"
                     Margin="28"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     Stretch="Uniform"
                     StretchDirection="DownOnly">
                <Border x:Name="DetailModal"
                        Width="980"
                        Height="630"
                        Padding="24"
                        CornerRadius="26"
                        BorderBrush="#40FFF7EC"
                        BorderThickness="1.2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFF9F0" Offset="0" />
                        <GradientStop Color="#F0DABB" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <ScrollViewer x:Name="DetailScrollViewer"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Padding="10"
                                    CornerRadius="22"
                                    Background="#FFF8EF"
                                    BorderBrush="#30A77E47"
                                    BorderThickness="1">
                                <Image x:Name="DetailImage"
                                       Height="450"
                                       Stretch="Uniform" />
                            </Border>

                            <StackPanel Grid.Column="2">
                                <WrapPanel VerticalAlignment="Center">
                                    <TextBox x:Name="DetailNameText"
                                             Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                             Width="620"
                                             FontSize="32"
                                             FontWeight="Bold"
                                             Foreground="#2A2118"
                                             ToolTip="可选择，也可双击复制" />
                                    <Border x:Name="EnchantBadge"
                                            Margin="12,6,0,0"
                                            Padding="10,4"
                                            CornerRadius="10"
                                            Background="#FFF3D6"
                                            BorderBrush="#CCB87924"
                                            BorderThickness="1"
                                            Visibility="Collapsed">
                                        <TextBox Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                                 FontSize="14"
                                                 FontWeight="Bold"
                                                 Foreground="#9A650D"
                                                 Text="附魔" />
                                    </Border>
                                </WrapPanel>

                                <WrapPanel Margin="0,14,0,0">
                                    <TextBox Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                             Width="68"
                                             FontSize="16"
                                             Foreground="#6A573F"
                                             Text="CardID: " />
                                    <TextBox x:Name="DetailCardIdValueText"
                                             Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                             Width="220"
                                             Margin="0,0,12,0"
                                             FontSize="16"
                                             Foreground="#8B5A1A"
                                             ToolTip="可选择，也可双击复制" />
                                    <TextBox Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                             Width="28"
                                             FontSize="16"
                                             Foreground="#6A573F"
                                             Text="ID: " />
                                    <TextBox x:Name="DetailDbfIdValueText"
                                             Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                             Width="120"
                                             FontSize="16"
                                             Foreground="#8B5A1A"
                                             ToolTip="可选择，也可双击复制" />
                                </WrapPanel>

                                <Border Margin="0,6,0,0"
                                        Padding="18"
                                        CornerRadius="18"
                                        Background="#F8EFE2"
                                        BorderBrush="#30A77E47"
                                        BorderThickness="1">
                                    <TextBox x:Name="DetailDescriptionText"
                                             Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                             FontSize="17"
                                             Foreground="#493B2A" />
                                </Border>

                                <Border x:Name="ParentSection"
                                        Margin="0,16,0,0"
                                        Padding="16"
                                        CornerRadius="16"
                                        Background="#EEF7FB"
                                        BorderBrush="#5097CAE4"
                                        BorderThickness="1"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBox Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                                 FontSize="17"
                                                 FontWeight="Bold"
                                                 Foreground="#28637C"
                                                 Text="【衍生自 / 主卡牌】" />
                                        <WrapPanel x:Name="ParentLinksPanel"
                                                   Margin="0,12,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="RelatedSection"
                                        Margin="0,14,0,0"
                                        Padding="16"
                                        CornerRadius="16"
                                        Background="#F6F0E5"
                                        BorderBrush="#50966F3D"
                                        BorderThickness="1"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBox Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                                 FontSize="17"
                                                 FontWeight="Bold"
                                                 Foreground="#6F4C20"
                                                 Text="【衍生 / 相关牌】" />
                                        <WrapPanel x:Name="RelatedLinksPanel"
                                                   Margin="0,12,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="EnchantmentSection"
                                        Margin="0,14,0,0"
                                        Padding="16"
                                        CornerRadius="16"
                                        Background="#FFF2DE"
                                        BorderBrush="#60D89A33"
                                        BorderThickness="1"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBox Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                                 FontSize="17"
                                                 FontWeight="Bold"
                                                 Foreground="#9A650D"
                                                 Text="【附魔】" />
                                        <WrapPanel x:Name="EnchantmentLinksPanel"
                                                   Margin="0,12,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Border Margin="0,22,0,0"
                                Padding="18"
                                CornerRadius="20"
                                Background="#FBF7F0"
                                BorderBrush="#30A77E47"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBox Style="{StaticResource SelectableDisplayTextBoxStyle}"
                                         FontSize="22"
                                         FontWeight="Bold"
                                         Foreground="#2A2118"
                                         Text="完整标签" />
                                <StackPanel x:Name="TagsPanel"
                                            Margin="0,16,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            </Viewbox>
        </Grid>

        <Button x:Name="BackToTopButton"
                Width="124"
                Height="48"
                Margin="0,0,24,84"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Content="回到顶部"
                Visibility="Collapsed" />

        <Border x:Name="ToastBorder"
                Margin="0,0,24,24"
                Padding="16,10"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="#D6302A21"
                CornerRadius="14"
                Visibility="Collapsed">
            <TextBlock x:Name="ToastTextBlock"
                       FontSize="16"
                       Foreground="#FFF8F1" />
        </Border>
    </Grid>
</Window>
